# Required API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=pcsk_...

# Pinecone config — create an index named "repo-explainer" with:
#   dimension: 1536, metric: cosine
PINECONE_INDEX_NAME=repo-explainer

# Optional: GitHub Personal Access Token for private repos / higher rate limits
# GITHUB_TOKEN=ghp_...  (uncomment and set for private repos)
